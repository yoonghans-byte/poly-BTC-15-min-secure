# ╔══════════════════════════════════════════════════════════════════╗
# ║          POLYMARKET TRADING BOT — ENVIRONMENT VARIABLES         ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# HOW TO USE THIS FILE:
#   1. Copy this file and rename it to ".env"
#      (On Mac/Linux: cp .env.example .env)
#      (On Windows:   copy .env.example .env)
#   2. Fill in your values below
#   3. NEVER share your .env file or commit it to Git
#
# The .env file is already in .gitignore so it won't be uploaded.

# ──────────────────────────────────────────────────────────────────
# LIVE TRADING (Required to trade with real money)
# ──────────────────────────────────────────────────────────────────
# Set to "true" to allow LIVE wallets to execute real trades.
# BOTH this variable AND config.yaml must enable live trading.
# Default: false (paper trading only — no real money used)
ENABLE_LIVE_TRADING=false

# ──────────────────────────────────────────────────────────────────
# POLYMARKET PRIVATE KEY (Required for LIVE trading)
# ──────────────────────────────────────────────────────────────────
# The private key of your Polymarket signer wallet (the EOA that
# signs orders on-chain).  This is NOT your Polymarket password.
#
# For Polymarket.com accounts (Google / Magic Link):
#   1. Go to polymarket.com → Profile → Export Private Key
#   2. Paste the key here (with or without the leading 0x)
#
# KEEP THIS SECRET — never share it or commit it to Git.
POLYMARKET_PRIVATE_KEY=

# Signature type (optional — default is POLY_PROXY for Polymarket.com accounts)
# Options: POLY_PROXY (default), EOA, POLY_GNOSIS_SAFE
# Use EOA only if you funded Polymarket directly with a hardware wallet.
POLYMARKET_SIG_TYPE=POLY_PROXY

# ──────────────────────────────────────────────────────────────────
# POLYMARKET API KEY (no longer needed — auto-derived from private key)
# ──────────────────────────────────────────────────────────────────
# The bot now derives its CLOB API credentials automatically from
# your private key.  You do NOT need to set this manually.
POLYMARKET_API_KEY=

# ──────────────────────────────────────────────────────────────────
# OPTIONAL SETTINGS
# ──────────────────────────────────────────────────────────────────

# Dashboard port (default: 3000)
# Change this if port 3000 is already in use on your machine.
DASHBOARD_PORT=3000

# Log level: trace | debug | info | warn | error | fatal
# Use "debug" to see more details, "info" for normal operation.
LOG_LEVEL=info
